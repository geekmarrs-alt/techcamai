# API
# When running under Docker with host networking (recommended on Pi), use localhost
API_BASE_URL=http://127.0.0.1:8000
API_PORT=8000

# Product shell (not yet enforced — see docs/PRODUCT_SHELL.md)
# SECRET_KEY: used for session signing and worker token derivation when auth is built
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# TECHCAMAI_LICENSE_KEY: leave blank for Community / Developer Preview
# Pro/Enterprise keys format: TCAM-XXXX-XXXX-XXXX
TECHCAMAI_LICENSE_KEY=

# DB
DB_PATH=/data/techcamai.db

# Worker
POLL_INTERVAL_SEC=30
CAMERA_SNAPSHOT_URLS=
# example (comma-separated):
# CAMERA_SNAPSHOT_URLS=http://user:pass@192.168.1.10/ISAPI/Streaming/channels/1/picture
CLIP_CAPTURE_ENABLED=1
CLIP_DURATION_SEC=12
CLIPS_DIR=/data/clips

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Ruflo / AI Orchestration (optional)
# Required to use Ruflo MCP server and AI-powered agent features.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: additional AI provider keys for Ruflo multi-provider routing
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Ruflo log level: debug | info | warn | error (default: info)
CLAUDE_FLOW_LOG_LEVEL=info
# Ruflo tool groups to enable (reduces latency by loading only what's needed)
# Options: implement, test, fix, memory, github, workers
CLAUDE_FLOW_TOOL_GROUPS=implement,test,fix,memory
